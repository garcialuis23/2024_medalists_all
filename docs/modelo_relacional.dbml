// Paris 2024 Medalists — Modelo Relacional
// Compatible con dbdiagram.io

Table country {
  country_id varchar [pk, note: 'Wikidata ID (ej. Q30)']
  name varchar [not null]
  code2 char(2)
  code3 char(3)
  ioc_code char(3)
}

Table delegation {
  delegation_id varchar [pk, note: 'Wikidata ID']
  name varchar [not null]
  link varchar
  country_id varchar [ref: > country.country_id]
}

Table sport {
  sport_id varchar [pk, note: 'Wikidata ID']
  name varchar [not null]
}

Table discipline {
  discipline_id varchar [pk, note: 'Wikidata ID']
  name varchar [not null]
  sport_id varchar [ref: > sport.sport_id]
}

Table event {
  event_id varchar [pk, note: 'Wikidata ID']
  name varchar [not null]
  link varchar
  discipline_id varchar [ref: > discipline.discipline_id]
}

Table nuts_region {
  nuts_id varchar [pk, note: 'Código NUTS (ej. ES61)']
  level smallint [not null, note: '0, 1, 2 o 3']
  name varchar [not null]
  parent_nuts_id varchar [ref: > nuts_region.nuts_id, note: 'NULL en nivel 0']
  population float
  gdp float
}

Table place {
  place_id varchar [pk, note: 'Wikidata ID']
  name varchar [not null]
  located_in_id varchar [ref: > place.place_id, note: 'Self-ref']
  lat float
  lon float
  nuts3_id varchar [ref: > nuts_region.nuts_id, note: 'NULL si no es Europa']
}

Table athlete {
  athlete_id varchar [pk, note: 'Wikidata ID']
  name varchar [not null]
  link varchar
  date_of_birth date
  sex_or_gender varchar
  place_id varchar [ref: > place.place_id]
}

Table medal {
  medal_id varchar [pk]
  athlete_id varchar [not null, ref: > athlete.athlete_id]
  event_id varchar [not null, ref: > event.event_id]
  delegation_id varchar [ref: > delegation.delegation_id]
  country_id varchar [ref: > country.country_id]
  type varchar [not null, note: 'gold / silver / bronze']

  indexes {
    (athlete_id, event_id) [unique, name: 'uq_athlete_event']
  }
}
